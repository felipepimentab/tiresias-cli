{
  "name": "tiresias-cli",
  "version": "0.1.2",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "tiresias": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "cli": "bun run src/index.ts",
    "install:local": "bash scripts/install-local.sh",
    "clean:dist": "rm -rf dist && mkdir -p dist",
    "build:macos": "bun build --compile --target=bun-darwin-arm64 --outfile=dist/tiresias-macos src/index.ts",
    "build:linux": "bun build --compile --target=bun-linux-x64 --outfile=dist/tiresias-linux src/index.ts",
    "build:windows": "bun build --compile --target=bun-windows-x64 --outfile=dist/tiresias-win.exe src/index.ts",
    "build:binaries": "bun run clean:dist && bun run build:macos && bun run build:linux && bun run build:windows",
    "version:patch": "bun run scripts/release.ts version patch",
    "version:minor": "bun run scripts/release.ts version minor",
    "version:major": "bun run scripts/release.ts version major",
    "release:patch": "bun run scripts/release.ts release patch",
    "release:minor": "bun run scripts/release.ts release minor",
    "release:major": "bun run scripts/release.ts release major"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}
